# ローカル開発で Wrangler によって使用されます
# 本番環境では、これらは Cloudflare Worker Secrets として設定する必要があります。

# Better Auth のシークレットキー
BETTER_AUTH_SECRET=

# Better Auth のベースURL。ローカル開発URLを設定してください。
BETTER_AUTH_URL=

# 許可するフロントエンドのURL（複数ある場合はカンマ区切り）
# ローカル開発環境の例:
FRONTEND_URL=http://localhost:3000

# (将来用) Cookieのドメイン指定
# 本番環境などでフロントエンドとAPIをサブドメインで分けてCookieを共有する場合に設定します。
# 例: .example.com
# ローカル開発時や単一ドメイン運用時は未設定で問題ありません。
# COOKIE_DOMAIN=

# ...その他の設定...
VERCEL_TEAM_SLUG=your-team-slug

# Notification (internal API / CLI 互換)
NOTIFICATION_INTERNAL_TOKEN=
# notifications:resend-api 用。未設定時は http://127.0.0.1:8787 を使用
# NOTIFICATION_API_BASE_URL=http://127.0.0.1:8787
# notifications:resend-api 用。未設定時は 10000 を使用
# NOTIFICATION_API_TIMEOUT_MS=10000
RESEND_API_KEY=
RESEND_FROM_EMAIL="Fumufumu <no-reply@mail.fumufumu.jp>"
# APP_BASE_URL=http://localhost:3000
# RESEND_ENDPOINT=https://api.resend.com/emails
# RESEND_TIMEOUT_MS=8000
