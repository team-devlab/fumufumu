{
  "name": "@fumufumu/frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "deploy:cf:require-approved": "test \"${DEPLOY_APPROVED:-}\" = \"1\" || (echo \"Set DEPLOY_APPROVED=1 to allow deploy\" && exit 1)",
    "deploy:cf:require-config": "test -f \"${WRANGLER_DEPLOY_CONFIG:-wrangler.local.jsonc}\" || (echo \"Wrangler deploy config not found: ${WRANGLER_DEPLOY_CONFIG:-wrangler.local.jsonc}\" && exit 1)",
    "deploy:cf": "pnpm deploy:cf:require-approved && pnpm deploy:cf:require-config && pnpm build:cf && wrangler deploy --config \"${WRANGLER_DEPLOY_CONFIG:-wrangler.local.jsonc}\"",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.6.0",
    "server-only": "^0.0.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.6",
    "wrangler": "^4.94.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
